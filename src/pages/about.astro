---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About the Creator">
  <section
    class="mx-auto flex min-h-[80vh] max-w-6xl items-center px-6 py-16 md:px-10 md:py-24 lg:py-28"
  >
    <div class="js-about-wrapper grid w-full gap-10 md:grid-cols-[minmax(0,1.2fr)_minmax(0,1.6fr)]">
      <div class="flex items-center justify-center">
        <div
          class="js-about-photo relative aspect-[4/5] w-full max-w-sm overflow-hidden rounded-3xl border border-white/10 bg-black/60 shadow-[0_24px_70px_rgba(0,0,0,0.9)]"
        >
          <img
            src="https://images.unsplash.com/photo-1511920170033-f8396924c348?q=80&w=1000&auto=format&fit=crop"
            alt="Moody cafe portrait in Bandung"
            class="h-full w-full object-cover"
            loading="lazy"
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent" />
        </div>
      </div>

      <div class="space-y-5 md:space-y-6">
        <h1 class="js-about-line text-3xl font-semibold tracking-tight md:text-4xl lg:text-5xl">
          About the <span class="text-[var(--color-accent)]">Creator.</span>
        </h1>

        <p class="js-about-line text-xs font-medium uppercase tracking-[0.28em] text-neutral-500">
          Bandung · Motion Design · Late-night Renders
        </p>

        <div class="space-y-4 text-sm leading-relaxed text-neutral-300 md:text-base">
          <p class="js-about-line">
            Pulangjamsebelas is a motion designer based in Bandung, West Java, who builds visual
            stories frame by frame. Between city lights and quiet backstreets, every project starts as
            a rough sketch and slowly evolves into a fully choreographed piece of moving image.
          </p>
          <p class="js-about-line">
            The work blends 3D, brutalist graphic language, and editorial pacing — always chasing that
            balance where typography, light, and rhythm feel like they belong to the same universe.
            From kinetic type experiments to client campaigns, each timeline is treated like a film
            sequence, not just a set of keyframes.
          </p>
          <p class="js-about-line">
            Most nights end long after midnight, with coffee in one hand and a pen tablet in the
            other. That late-hour focus is where pulangjamsebelas feels most at home: tweaking curves,
            nudging frames by a few milliseconds, and searching for visuals that feel honest, sharp,
            and slightly unexpected.
          </p>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    if (typeof window !== "undefined") {
      gsap.registerPlugin(ScrollTrigger);

      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)")
        ?.matches;

      if (!prefersReduced) {
        gsap.from(".js-about-line", {
          y: 24,
          opacity: 0,
          duration: 0.9,
          ease: "power3.out",
          stagger: 0.12,
          scrollTrigger: {
            trigger: ".js-about-wrapper",
            start: "top 75%",
          },
        });

        gsap.to(".js-about-photo", {
          yPercent: -8,
          ease: "none",
          scrollTrigger: {
            trigger: ".js-about-wrapper",
            start: "top bottom",
            end: "bottom top",
            scrub: true,
          },
        });
      }
    }
  </script>
</Layout>

