---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const href = `/works/${project.slug}`;
---

<a href={href} class="group block h-full" data-cursor="hover">
  <article
    class="flex h-full flex-col overflow-hidden rounded-2xl border border-white/10 bg-black/70 shadow-[0_18px_50px_rgba(0,0,0,0.9)] transition-all duration-300 hover:-translate-y-2 hover:border-[var(--color-accent)]/60 hover:shadow-[0_26px_70px_rgba(0,0,0,0.95)]"
  >
    <div class="relative aspect-video w-full overflow-hidden">
      <img
        src={project.data.image}
        alt={project.data.title}
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
      />
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-90" />
    </div>

    <div class="flex flex-1 flex-col gap-3 p-5 md:p-6">
      <div class="flex items-center justify-between gap-3">
        <span
          class="inline-flex items-center rounded-full border border-[var(--color-accent)]/60 bg-[var(--color-accent)]/10 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-[var(--color-accent)]"
        >
          {project.data.category}
        </span>
        <span class="text-[0.7rem] uppercase tracking-[0.18em] text-neutral-500">
          {project.data.publishDate.toLocaleDateString("en-US", {
            month: "short",
            year: "numeric",
          })}
        </span>
      </div>

      <h3 class="text-xl font-bold tracking-tight md:text-2xl">
        {project.data.title}
      </h3>

      <p class="text-xs text-neutral-400 md:text-sm">
        {project.data.excerpt}
      </p>
    </div>
  </article>
</a>

