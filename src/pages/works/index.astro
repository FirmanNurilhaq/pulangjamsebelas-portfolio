---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import ProjectCard from "../../components/ProjectCard.astro";

const projects = await getCollection("projects");
---

<Layout title="Works">
  <section class="relative px-6 py-20 md:px-10 md:py-28 lg:px-20 lg:py-32">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_#1d1d1f_0,_#000_55%)] opacity-80"
    >
    </div>

    <div class="relative z-10 mx-auto flex max-w-6xl flex-col gap-10">
      <header class="max-w-3xl">
        <a
          href="/"
          class="mb-8 inline-flex w-fit items-center gap-2 rounded-full border border-white/10 bg-white/5 px-5 py-2 text-xs uppercase tracking-[0.15em] text-white backdrop-blur-md transition-all hover:bg-white hover:text-black md:mb-12"
        >
          ← Back to Home
        </a>
        <p
          class="text-xs font-medium tracking-[0.28em] text-neutral-500 uppercase"
        >
          All works
        </p>
        <h1
          class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl lg:text-5xl"
        >
          Cinematic projects by{" "}
          <span class="text-[var(--color-accent)]">pulangjamsebelas</span>.
        </h1>
      </header>

      <div class="grid grid-cols-1 gap-7 md:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</Layout>
